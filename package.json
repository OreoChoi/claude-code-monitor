{
  "name": "claude-code-monitor",
  "version": "0.1.0",
  "description": "A tiny local web UI that streams your active Claude Code CLI session in real time. Zero dependencies.",
  "type": "module",
  "main": "monitor.mjs",
  "bin": {
    "claude-code-monitor": "./monitor.mjs"
  },
  "scripts": {
    "start": "node monitor.mjs",
    "screenshot": "node scripts/screenshot.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "monitor",
    "observability",
    "sse",
    "cli"
  ],
  "author": "OreoChoi",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "monitor.mjs",
    "start.command",
    "stop.command",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OreoChoi/claude-code-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/OreoChoi/claude-code-monitor/issues"
  },
  "homepage": "https://github.com/OreoChoi/claude-code-monitor#readme",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "ws": "^8.20.1"
  }
}
